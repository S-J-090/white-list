local function findNearestWaypointIndex(pos, excludeIndex)
	local bestIndex = 1
	local bestDist = math.huge
	for i = 1, #waypoints do
		if i == excludeIndex then continue end 
		local d = (waypoints[i] - pos).Magnitude
		if d < bestDist then
			bestDist = d
			bestIndex = i
		end
	end
	return bestIndex
end
