local function handleStuck()
    if isStuckHandling then return end
    isStuckHandling = true
    showMessage("STUCK! Finding waypoint...", 3)
    humanoid.Jump = true
    
    triedWaypoints = {}
    stuckRetryCount = 0
    
    local candidateIndex = findNearestWaypointIndex(root.Position)
    stuckTargetIndex = candidateIndex
    stuckTargetPos = waypoints[candidateIndex]
    stuckHandlingStartTime = tick()
    table.insert(triedWaypoints, candidateIndex)
    excludedWaypointIndex = candidateIndex
end

local function enableForces()
	bv.Parent = root
end

local function disableForces()
	bv.Parent = nil
end

UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end

	if input.KeyCode == Enum.KeyCode.RightAlt then
		paused = not paused
		if paused then
			disableForces()
		else
			index = 1
			enableForces()
		end
	end

	if input.KeyCode == Enum.KeyCode.LeftAlt then
		index = findNearestWaypointIndex(root.Position)
		paused = false
		enableForces()
		stuckTimer = 0
	end
end)


