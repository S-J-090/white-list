local function trackGold(node)
	if node:IsA("Model") and node.Name == "Gold Node" then
		local part = node.PrimaryPart or node:FindFirstChildWhichIsA("BasePart")
		local healthValue = node:FindFirstChild("Health")
		if part and healthValue and healthValue:IsA("IntValue") then
			goldNodes[node] = { part = part, health = healthValue }
			node.Destroying:Once(function()
				goldNodes[node] = nil
			end)
		end
	end
end

for _, n in ipairs(Resources:GetChildren()) do
