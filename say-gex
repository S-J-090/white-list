local function updateDirectionLine(targetPos, color)
	if not root or not targetPos then
		if directionLine then
			directionLine:Destroy()
			directionLine = nil
		end
		return
	end
	
	local charPos = root.Position
	local delta = targetPos - charPos
	local distance = delta.Magnitude
	
	if distance < 0.1 then
		if directionLine then
			directionLine:Destroy()
			directionLine = nil
		end
		return
	end
	
	if not directionLine or not directionLine.Parent then
		directionLine = Instance.new("Part")
		directionLine.Name = "DirectionLine"
		directionLine.Anchored = true
		directionLine.CanCollide = false
		directionLine.CastShadow = false
		directionLine.Transparency = 0.1
		directionLine.Color = color or Color3.fromRGB(0, 255, 100)
		directionLine.Material = Enum.Material.Neon
		directionLine.Size = Vector3.new(0.25, 0.25, 1)
		directionLine.Parent = workspace
	end
	
	local midPoint = charPos + delta * 0.5
	directionLine.Position = midPoint
	directionLine.Size = Vector3.new(0.20, 0.20, math.max(1, distance))
	directionLine.CFrame = CFrame.new(midPoint, midPoint + delta.Unit)
end

local function hideDirectionLine()
	if directionLine then
		directionLine:Destroy()
		directionLine = nil
	end
end
local function deleteUnwantedObjects()
    local keywords = {"mound", "rock", "boat", "treasure", "meteor"}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if not obj:IsA("Model") and not obj:IsA("BasePart") and not obj:IsA("Folder") then 
            continue 
        end

        local name = obj.Name
        local lowerName = string.lower(name)
        if obj.Parent == Resources and name ~= "Gold Node" then
            obj:Destroy()
            continue
        end
        if name == "Critters" then
            obj:Destroy()
            continue
        end
        if name == "Cave Spikes" then
            obj:Destroy()
            continue
        end

        for _, keyword in ipairs(keywords) do
            if string.find(lowerName, keyword, 1, true) and name ~= "Gold Node" then
                obj:Destroy()
                break
            end
        end
    end
end
