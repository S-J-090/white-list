if isStuckHandling then
    local currentMovedDist = (root.Position - lastPos).Magnitude
    if stuckTargetPos then
        updateDirectionLine(stuckTargetPos, Color3.fromRGB(255, 60, 60))
    end
    
    if currentMovedDist >= POSITION_STUCK_THRESHOLD then 
        isStuckHandling = false
        hideDirectionLine()
        stuckTargetPos = nil
        stuckTargetIndex = nil 
        label.Visible = false
        triedWaypoints = {}
        stuckRetryCount = 0
        stuckTimer = 0
        lastPos = root.Position
        showMessage("Unstuck after " .. stuckRetryCount .. " retries", 2)
    else
        if stuckTargetPos then
            local distToTarget = (root.Position - stuckTargetPos).Magnitude

            if distToTarget < ARRIVE_DISTANCE then
                index = stuckTargetIndex
                
                isStuckHandling = false
                hideDirectionLine()
                stuckTargetPos = nil
                stuckTargetIndex = nil
                label.Visible = false
                triedWaypoints = {}
                stuckRetryCount = 0
                stuckTimer = 0
                lastPos = root.Position
                showMessage("Resuming path from WP " .. index, 2)
                return 
            else
                local delta = stuckTargetPos - root.Position
                local dir = delta.Magnitude > 0 and delta.Unit or Vector3.zero
                local speed = getCurrentSpeed() 
                local desiredVel = dir * speed

                local heightDiff = stuckTargetPos.Y - root.Position.Y
                if heightDiff > 0 then
                    desiredVel += Vector3.new(0, math.clamp(heightDiff * 1.5, 0, 15), 0)
                end

                bv.Velocity = bv.Velocity:Lerp(desiredVel, LERP_ALPHA)
                if tick() - stuckHandlingStartTime >= STUCK_RETRY_TIMEOUT then
                    local newIndex = nil
                    local bestDist = math.huge
                    
                    for i = 1, #waypoints do
                        local alreadyTried = false
                        for _, tried in ipairs(triedWaypoints) do
                            if i == tried then
                                alreadyTried = true
                                break
                            end
                        end
                        if alreadyTried then continue end
                        
                        local d = (waypoints[i] - root.Position).Magnitude
                        if d < bestDist then
                            bestDist = d
                            newIndex = i
                        end
                    end
                    
                    if newIndex and waypoints[newIndex] and stuckRetryCount < MAX_STUCK_RETRIES then
                        stuckTargetIndex = newIndex 
                        stuckTargetPos = waypoints[newIndex]
                        
                        stuckHandlingStartTime = tick()
                        table.insert(triedWaypoints, newIndex)
                        stuckRetryCount += 1
                        showMessage("Retry " .. stuckRetryCount .. " - Moving to WP " .. newIndex, 2)
                    else
                        showMessage("Fallback - resetting to WP 1", 3)
                        index = 1
                        isStuckHandling = false
                        hideDirectionLine()
                        stuckTargetPos = nil
                        stuckTargetIndex = nil
                        label.Visible = false
                        triedWaypoints = {}
                        stuckRetryCount = 0
                    end
                end
            end
        end
    end
    
    if isStuckHandling and stuckTargetPos then
        return
    end
end

