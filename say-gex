local function isNearSignificantGold()
	local p = root.Position
	for _, data in pairs(goldNodes) do
		if data and data.part and data.health then
			local part = data.part
			local health = data.health
			if not part or not part.Parent or not health or not health.Parent then
				continue
			end
			if (part.Position - p).Magnitude^2 <= GOLD_RANGE_SQ then
				if health.Value >= 10 then
					return true
				end
			end
		end
	end
	return false
end
local function getNearbyGoldNode()
	local p = root.Position
	for _, data in pairs(goldNodes) do
		if data.part and data.health and data.part.Parent and data.health.Parent then
			if (data.part.Position - p).Magnitude^2 <= GOLD_RANGE_SQ then
				return data.health
			end
		end
	end
	return nil
end
